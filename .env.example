# Server
PORT=5000
API_BASE_URL=http://localhost:5000
CLIENT_URL=http://localhost:5173

# Meta app
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
# Optional: set this if Meta shows a separate Instagram App ID for Instagram Login.
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
META_GRAPH_VERSION=v23.0
INSTAGRAM_GRAPH_VERSION=v25.0

# Meta login configurations from your app
FACEBOOK_CONFIG_ID_PUBLISHING=1304153965041291
INSTAGRAM_WITH_FACEBOOK_CONFIG_ID=965975182701009
# Direct Instagram Login uses scopes, not a Facebook Login configuration ID.

# OAuth callbacks configured in Meta Developer Console
FACEBOOK_REDIRECT_URI=http://localhost:5000/api/auth/facebook/callback
INSTAGRAM_REDIRECT_URI=http://localhost:5000/api/auth/instagram/callback

# Facebook Login scopes for Pages and Instagram-via-Facebook
FACEBOOK_SCOPES=pages_show_list,pages_read_engagement,pages_manage_posts,instagram_basic,instagram_content_publish

# Instagram Login scopes for direct Instagram integration
INSTAGRAM_SCOPES=instagram_business_basic,instagram_business_content_publish
INSTAGRAM_EXCHANGE_LONG_LIVED_TOKEN=false
INSTAGRAM_LOOKUP_PROFILE=false

# Client
VITE_API_BASE_URL=http://localhost:5000
